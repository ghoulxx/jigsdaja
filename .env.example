# Example environment variables for Railway or other hosts
# Rename to `.env` for local testing (don't commit your real token)

# Discord bot token
BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Command prefix
PREFIX=.

# Minecraft server host/IP and port
SERVER_HOST=YOUR_SERVER_IP_HERE
SERVER_PORT=25565

# Cache TTL in milliseconds (default 15000 = 15s)
CACHE_TTL=15000

# Presence update interval in milliseconds (default 300000 = 5m)
PRESENCE_INTERVAL=300000

# Bot name used in embed footers
BOT_NAME=Minecraft Status Bot
